FROM node:24-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --omit=dev

COPY scripts ./scripts

ENV HOST=0.0.0.0
ENV PORT=1234
ENV ROOM_SNAPSHOT_STORE_FILE=/app/runtime-data/room-snapshots.json
ENV ROOM_IDENTITY_STORE_FILE=/app/runtime-data/room-identities.json

EXPOSE 1234

CMD ["node", "./scripts/yjs-dev-server.mjs"]
