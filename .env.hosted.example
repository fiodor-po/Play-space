# For the cheapest hosted core deploy, keep media disabled.
# For the hosted video enable pass, switch this to true and set the LiveKit values below.
VITE_Y_WEBSOCKET_URL=wss://api.example.com
VITE_API_BASE_URL=https://api.example.com
VITE_LIVEKIT_URL=wss://livekit.example.com
VITE_ENABLE_LIVEKIT_MEDIA=false
HOST=0.0.0.0
PORT=1234
ROOM_SNAPSHOT_STORE_FILE=./runtime-data/room-snapshots.json
ROOM_IDENTITY_STORE_FILE=./runtime-data/room-identities.json
# Set these only when enabling hosted video.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
