VITE_Y_WEBSOCKET_URL=wss://192.168.1.10:3444
VITE_API_BASE_URL=https://192.168.1.10:3444
VITE_LIVEKIT_URL=wss://192.168.1.10:3445
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
